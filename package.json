{
  "name": "qr-studio",
  "version": "1.0.0",
  "description": "Image-styled, scannable QR code generator (links, email, WhatsApp, Wi-Fi, vCard and more).",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build && node --experimental-strip-types scripts/gen-sitemap.mjs && node --experimental-strip-types scripts/prerender.mjs",
    "prerender": "node --experimental-strip-types scripts/prerender.mjs",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/verify.mjs",
    "verify:card": "node scripts/card-check.mjs",
    "example": "node scripts/example.mjs"
  },
  "keywords": [
    "qr",
    "qrcode",
    "halftone",
    "generator"
  ],
  "license": "MIT",
  "dependencies": {
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-router-dom": "^7.18.1"
  },
  "devDependencies": {
    "@resvg/resvg-js": "^2.6.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "jpeg-js": "^0.4.4",
    "playwright-core": "^1.61.1",
    "pngjs": "^7.0.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.0"
  }
}
