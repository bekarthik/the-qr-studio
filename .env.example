# Support / payment links (all optional, all public — NO secret keys here).
# Copy to `.env` (or set in your host's dashboard) and fill in what you use.
# Any value left blank hides that option. See src/config/support.ts.

# Buy Me a Coffee handle → https://www.buymeacoffee.com/<handle>
VITE_SUPPORT_BMC=

# Ko-fi handle → https://ko-fi.com/<handle>
VITE_SUPPORT_KOFI=

# GitHub Sponsors handle → https://github.com/sponsors/<handle>
VITE_SUPPORT_GITHUB=

# Stripe: paste a hosted Payment Link URL (Dashboard → Payment links).
# This is safe to expose; never put a Stripe secret/restricted key in a frontend.
VITE_SUPPORT_STRIPE_URL=

# PayPal.me handle → https://paypal.me/<handle>
VITE_SUPPORT_PAYPAL=

# UPI VPA (India) → upi://pay?pa=<vpa> (opens a UPI app on mobile)
VITE_SUPPORT_UPI=

# --- Contact form → Supabase (both required to enable /contact submissions) ---
# Project URL: Supabase Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL=

# PUBLISHABLE key (starts with sb_publishable_…) from Settings → API Keys.
# Do NOT use a legacy anon key (a JWT starting eyJ…) — the app rejects those —
# and NEVER a service_role/secret key. Safety comes from RLS: the table only
# allows INSERT (see docs/runbooks/contact-supabase.md).
VITE_SUPABASE_PUBLISHABLE_KEY=
# --- Analytics: Umami Cloud (optional, free, cookieless) ---
# Website ID from Umami → your website → Settings. It is PUBLIC (ships in the
# page), so set it as a repo *variable* in CI, not a secret. Blank = analytics
# off. See docs/runbooks/analytics.md.
VITE_UMAMI_WEBSITE_ID=
# Optional — override the tracker host for a self-hosted Umami (default below).
# VITE_UMAMI_SRC=https://cloud.umami.is/script.js
