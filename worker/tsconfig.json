{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    // The Worker runtime exposes standard Web APIs (Response, Request, URL,
    // caches, WebAssembly, fetch). DOM also satisfies the browser-only sibling
    // modules in the shared core that this build transitively references.
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "allowImportingTsExtensions": true
  },
  "include": ["src"]
}
